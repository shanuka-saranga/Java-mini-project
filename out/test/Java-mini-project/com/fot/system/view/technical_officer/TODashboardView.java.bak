package com.fot.system.view.technical_officer;

import com.fot.system.config.AppTheme;
import com.fot.system.controller.TOController;
import com.fot.system.model.TechnicalOfficer;

import javax.swing.*;
import java.awt.*;
import java.awt.event.MouseAdapter;
import java.awt.event.MouseEvent;

/**
 * TODashboardView - Main window for Technical Officer.
 * Contains a sidebar for navigation and a content panel that swaps panels.
 * Demonstrates: GUI, Encapsulation
 */
public class TODashboardView extends JFrame {

    private final TOController controller;
    private final TechnicalOfficer user;

    private JPanel contentPanel;
    private CardLayout cardLayout;

    // Sidebar menu item names
    private static final String PANEL_HOME        = "HOME";
    private static final String PANEL_ATTENDANCE  = "ATTENDANCE";
    private static final String PANEL_MEDICALS    = "MEDICALS";
    private static final String PANEL_NOTICES     = "NOTICES";
    private static final String PANEL_TIMETABLE   = "TIMETABLE";
    private static final String PANEL_PROFILE     = "PROFILE";

    public TODashboardView(TechnicalOfficer user) {
        this.user = user;
        this.controller = new TOController(user);
        initUI();
    }

    private void initUI() {
        setTitle("TEC-SIS  |  Technical Officer  —  " + user.getFullName());
        setSize(1100, 680);
        setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
        setLocationRelativeTo(null);
        setLayout(new BorderLayout());

        add(buildSidebar(), BorderLayout.WEST);
        add(buildContentArea(), BorderLayout.CENTER);

        // Show home panel by default
        showPanel(PANEL_HOME);
    }

    // ──────────────────────────────────────────────────────────
    // SIDEBAR
    // ──────────────────────────────────────────────────────────
    private JPanel buildSidebar() {
        JPanel sidebar = new JPanel();
        sidebar.setPreferredSize(new Dimension(210, 0));
        sidebar.setBackground(AppTheme.SIDEBAR_BG);
        sidebar.setLayout(new BorderLayout());

        // Top: logo / title
        JPanel top = new JPanel(new FlowLayout(FlowLayout.CENTER, 0, 20));
        top.setOpaque(false);
        JLabel title = new JLabel("TEC-SIS");
        title.setFont(AppTheme.TITLE_FONT);
        title.setForeground(AppTheme.TEXT_LIGHT);
        top.add(title);
        sidebar.add(top, BorderLayout.NORTH);

        // Middle: menu items
        JPanel menu = new JPanel();
        menu.setOpaque(false);
        menu.setLayout(new BoxLayout(menu, BoxLayout.Y_AXIS));

        menu.add(menuItem("🏠  Home",        PANEL_HOME));
        menu.add(menuItem("📋  Attendance",  PANEL_ATTENDANCE));
        menu.add(menuItem("🏥  Medicals",    PANEL_MEDICALS));
        menu.add(menuItem("📢  Notices",     PANEL_NOTICES));
        menu.add(menuItem("📅  Timetable",   PANEL_TIMETABLE));
        menu.add(menuItem("👤  Profile",     PANEL_PROFILE));

        sidebar.add(menu, BorderLayout.CENTER);

        // Bottom: logout
        JPanel bottom = new JPanel(new FlowLayout(FlowLayout.CENTER, 0, 12));
        bottom.setOpaque(false);
        JButton logout = new JButton("Logout");
        logout.setFont(AppTheme.BUTTON_FONT);
        logout.setForeground(AppTheme.TEXT_LIGHT);
        logout.setBackground(AppTheme.PRIMARY_ACTIVE);
        logout.setBorderPainted(false);
        logout.setFocusPainted(false);
        logout.setCursor(Cursor.getPredefinedCursor(Cursor.HAND_CURSOR));
        logout.setPreferredSize(new Dimension(160, 36));
        logout.addActionListener(e -> {
            int c = JOptionPane.showConfirmDialog(this, "Logout?", "Confirm", JOptionPane.YES_NO_OPTION);
            if (c == JOptionPane.YES_OPTION) {
                dispose();
                // Re-open login screen
                com.fot.system.view.login.LoginView login = new com.fot.system.view.login.LoginView("", "");
                login.setVisible(true);
            }
        });
        bottom.add(logout);
        sidebar.add(bottom, BorderLayout.SOUTH);

        return sidebar;
    }

    private JPanel menuItem(String label, String panelKey) {
        JPanel item = new JPanel(new FlowLayout(FlowLayout.LEFT, 20, 12));
        item.setOpaque(false);
        item.setMaximumSize(new Dimension(210, 50));
        item.setCursor(Cursor.getPredefinedCursor(Cursor.HAND_CURSOR));

        JLabel lbl = new JLabel(label);
        lbl.setFont(AppTheme.MENU_FONT);
        lbl.setForeground(AppTheme.TEXT_LIGHT);
        item.add(lbl);

        item.addMouseListener(new MouseAdapter() {
            @Override public void mouseClicked(MouseEvent e) { showPanel(panelKey); }
            @Override public void mouseEntered(MouseEvent e) { item.setOpaque(true); item.setBackground(AppTheme.PRIMARY_HOVER); item.repaint(); }
            @Override public void mouseExited(MouseEvent e)  { item.setOpaque(false); item.repaint(); }
        });

        return item;
    }

    // ──────────────────────────────────────────────────────────
    // CONTENT AREA
    // ──────────────────────────────────────────────────────────
    private JPanel buildContentArea() {
        cardLayout = new CardLayout();
        contentPanel = new JPanel(cardLayout);
        contentPanel.setBackground(AppTheme.CONTENT_BG);

        contentPanel.add(buildHomePanel(),                    PANEL_HOME);
        contentPanel.add(new AttendancePanel(controller),    PANEL_ATTENDANCE);
        contentPanel.add(new MedicalPanel(controller),       PANEL_MEDICALS);
        contentPanel.add(new TONoticePanel(),                 PANEL_NOTICES);
        contentPanel.add(new TOTimetablePanel(user),         PANEL_TIMETABLE);
        contentPanel.add(new TOProfilePanel(controller),     PANEL_PROFILE);

        return contentPanel;
    }

    private JPanel buildHomePanel() {
        JPanel p = new JPanel(new GridBagLayout());
        p.setBackground(AppTheme.CONTENT_BG);
        GridBagConstraints gbc = new GridBagConstraints();
        gbc.insets = new Insets(8, 8, 8, 8);

        JLabel welcome = new JLabel("Welcome, " + user.getFullName() + "!");
        welcome.setFont(AppTheme.TITLE_FONT);
        welcome.setForeground(AppTheme.PRIMARY);
        gbc.gridx = 0; gbc.gridy = 0; gbc.gridwidth = 2;
        p.add(welcome, gbc);

        JLabel role = new JLabel("Role: Technical Officer   |   Staff Code: " + user.getStaffCode());
        role.setFont(AppTheme.LABEL_FONT);
        role.setForeground(AppTheme.TEXT_MUTED);
        gbc.gridy = 1;
        p.add(role, gbc);

        gbc.gridy = 2; gbc.gridwidth = 1;
        p.add(quickCard("📋 Attendance",  "Manage student attendance",  PANEL_ATTENDANCE), gbc);
        gbc.gridx = 1;
        p.add(quickCard("🏥 Medicals",   "Review medical certificates", PANEL_MEDICALS),  gbc);
        gbc.gridx = 0; gbc.gridy = 3;
        p.add(quickCard("📢 Notices",    "View faculty notices",        PANEL_NOTICES),    gbc);
        gbc.gridx = 1;
        p.add(quickCard("📅 Timetable",  "View department timetable",   PANEL_TIMETABLE),  gbc);

        return p;
    }

    private JPanel quickCard(String title, String desc, String panelKey) {
        JPanel card = new JPanel(new BorderLayout(0, 4));
        card.setBackground(AppTheme.CARD_BG);
        card.setBorder(BorderFactory.createCompoundBorder(
                BorderFactory.createLineBorder(AppTheme.BORDER_LIGHT, 1, true),
                BorderFactory.createEmptyBorder(16, 20, 16, 20)));
        card.setPreferredSize(new Dimension(200, 90));
        card.setCursor(Cursor.getPredefinedCursor(Cursor.HAND_CURSOR));

        JLabel t = new JLabel(title);
        t.setFont(AppTheme.SUB_TITLE_FONT);
        t.setForeground(AppTheme.PRIMARY);
        card.add(t, BorderLayout.NORTH);

        JLabel d = new JLabel("<html>" + desc + "</html>");
        d.setFont(AppTheme.LABEL_FONT);
        d.setForeground(AppTheme.TEXT_MUTED);
        card.add(d, BorderLayout.CENTER);

        card.addMouseListener(new MouseAdapter() {
            @Override public void mouseClicked(MouseEvent e) { showPanel(panelKey); }
            @Override public void mouseEntered(MouseEvent e) { card.setBackground(AppTheme.TABLE_SELECTION_BG); card.repaint(); }
            @Override public void mouseExited(MouseEvent e)  { card.setBackground(AppTheme.CARD_BG); card.repaint(); }
        });

        return card;
    }

    public void showPanel(String panelKey) {
        cardLayout.show(contentPanel, panelKey);
    }
}
